{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",

  "metadata": [
    {
      "src": {
        "cwd": "..",
        "files": [
          "Library/ScriptAssemblies/Assembly-CSharp.dll",
          "Library/ScriptAssemblies/Assembly-CSharp-Editor.dll"
        ]
      },
      "dest": "api"
    }
  ],

  "build": {
    "content": [
      {
        "files": [
          "index.md",
          "toc.yml"
        ]
      },
      {
        "src": "api",
        "files": [
          "*.yml"
        ],
        "dest": "api"
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "template": [
      "default",
      "modern"
    ],
    "output": "_site",
    "globalMetadata": {
      "_appName": "Virtual Tour Template Docs",
      "_appTitle": "Virtual Tour Template Docs",
      "_enableSearch": true
    }
  }
}
